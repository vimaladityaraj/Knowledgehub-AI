# ══════════════════════════════════════════════════════════════════════════════
# KnowledgeHub AI – Environment Variables
# Copy this file to .env and fill in your values.
# ══════════════════════════════════════════════════════════════════════════════

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Supported values: "anthropic" | "openai" | "ollama"
LLM_PROVIDER=anthropic

# ── Anthropic (provider=anthropic) ────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=claude-3-5-sonnet-20241022

# ── OpenAI (provider=openai) ──────────────────────────────────────────────────
# Set LLM_PROVIDER=openai and update LLM_MODEL to use OpenAI instead.
OPENAI_API_KEY=sk-...
# LLM_MODEL=gpt-4o

# ── Ollama (provider=ollama) ──────────────────────────────────────────────────
# Run Ollama locally: https://ollama.com
# Then pull a model:  ollama pull qwen3:8b
#                     ollama pull llama3
# Set LLM_PROVIDER=ollama — no API key needed.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b
# Other supported models: llama3, llama3.1, mistral, phi3, gemma2, deepseek-r1

# ── Embeddings ────────────────────────────────────────────────────────────────
# Runs locally via sentence-transformers — no API key needed for any provider.
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# ── Retrieval ─────────────────────────────────────────────────────────────────
TOP_K_RESULTS=5

# ── Paths ─────────────────────────────────────────────────────────────────────
UPLOAD_DIR=data/uploads
VECTOR_DIR=data/vectors

# ── FastAPI ───────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Streamlit ─────────────────────────────────────────────────────────────────
STREAMLIT_API_BASE_URL=http://localhost:8000
